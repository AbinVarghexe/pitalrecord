# Environment Variables Template for EC2 Instance
# Copy this file to .env and fill in your actual values

# ============================================
# Supabase Configuration
# ============================================
# Get these from: https://app.supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# Site URL (Production)
# ============================================
# Your production domain or IP (used for OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://13-223-71-71.nip.io

# ============================================
# Node Environment
# ============================================
NODE_ENV=production

# ============================================
# AWS ECR Configuration (for EC2 deployment)
# ============================================
# Get these from AWS ECR Console
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
ECR_REPOSITORY=pitalrecord

# ============================================
# Optional: Custom Configuration
# ============================================
# PORT=3000
# HOSTNAME=0.0.0.0

# ============================================
# Notes:
# ============================================
# - Never commit this file to Git (it's in .gitignore)
# - Keep this file secure on your EC2 instance
# - Update values when rotating credentials
# - For GitHub Actions, use GitHub Secrets instead
